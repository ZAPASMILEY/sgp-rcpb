@startuml SGP-RCPB — Diagramme de classes

!theme plain
skinparam backgroundColor #FAFAFA
skinparam ArrowColor #334155
skinparam ClassBorderColor #475569
skinparam ClassBackgroundColor #f8fafc
skinparam ClassFontSize 12
skinparam ClassAttributeFontSize 11
skinparam ClassStereotypeFontSize 10
skinparam PackageBorderColor #94a3b8
skinparam PackageBackgroundColor #f1f5f9
skinparam PackageFontSize 13
skinparam PackageFontStyle bold
skinparam linetype ortho
skinparam nodesep 50
skinparam ranksep 60

' ═══════════════════════════════════════════════════════════════════
'  PACKAGE : AUTHENTIFICATION & UTILISATEURS
' ═══════════════════════════════════════════════════════════════════
package "Authentification & Utilisateurs" #e0f2fe {

    class User {
        + id : int <<PK>>
        + agent_id : int <<FK>>
        + manager_id : int <<FK, nullable>>
        + name : string
        + email : string
        + role : string
        + is_active : bool
        + must_change_password : bool
        + theme_preference : string
        + email_verified_at : datetime
        --
        + agent() : BelongsTo<Agent>
        + manager() : BelongsTo<User>
        + subordonnesDirects() : HasMany<User>
        + evaluations() : HasMany<Evaluation>
        + alertes() : BelongsToMany<Alerte>
        + activites() : HasMany<Activite>
    }

    class LoginFailure {
        + id : int <<PK>>
        + email : string
        + ip_address : string
        + user_agent : string
        + attempted_at : datetime
    }

    class Activite {
        + id : int <<PK>>
        + user_id : int <<FK>>
        + action : string
        + description : string
        + ip_address : string
        + user_agent : string
        --
        + user() : BelongsTo<User>
    }

    class Alerte {
        + id : int <<PK>>
        + created_by : int <<FK, nullable>>
        + type : string
        + priorite : string
        + titre : string
        + message : text
        + statut : string
        + ip_address : string
        --
        + createur() : BelongsTo<User>
        + destinataires() : BelongsToMany<User>
    }
}

' ═══════════════════════════════════════════════════════════════════
'  PACKAGE : STRUCTURE ORGANISATIONNELLE
' ═══════════════════════════════════════════════════════════════════
package "Structure Organisationnelle" #dcfce7 {

    class Entite {
        + id : int <<PK>>
        + nom : string
        + ville : string
        + region : string
        + secretariat_telephone : string
        + dg_agent_id : int <<FK, nullable>>
        + dga_agent_id : int <<FK, nullable>>
        + dga_secretaire_agent_id : int <<FK, nullable>>
        + pca_agent_id : int <<FK, nullable>>
        + assistante_agent_id : int <<FK, nullable>>
        --
        + dg() : BelongsTo<Agent>
        + dga() : BelongsTo<Agent>
        + dgaSecretaire() : BelongsTo<Agent>
        + pca() : BelongsTo<Agent>
        + assistante() : BelongsTo<Agent>
        + directions() : HasMany<Direction>
        + delegationTechniques() : HasMany<DelegationTechnique>
        + objectifs() : MorphMany<Objectif>
    }

    class Direction {
        + id : int <<PK>>
        + entite_id : int <<FK>>
        + nom : string
        + directeur_agent_id : int <<FK, nullable>>
        + secretaire_agent_id : int <<FK, nullable>>
        --
        + entite() : BelongsTo<Entite>
        + directeur() : BelongsTo<Agent>
        + secretaire() : BelongsTo<Agent>
        + services() : HasMany<Service>
        + agents() : HasMany<Agent>
        + caisses() : HasMany<Caisse>
        + objectifs() : MorphMany<Objectif>
    }

    class Service {
        + id : int <<PK>>
        + nom : string
        + direction_id : int <<FK, nullable>>
        + delegation_technique_id : int <<FK, nullable>>
        + caisse_id : int <<FK, nullable>>
        + chef_agent_id : int <<FK, nullable>>
        --
        + direction() : BelongsTo<Direction>
        + delegationTechnique() : BelongsTo<DelegationTechnique>
        + caisse() : BelongsTo<Caisse>
        + chef() : BelongsTo<Agent>
        + agents() : HasMany<Agent>
        + objectifs() : MorphMany<Objectif>
    }

    class DelegationTechnique {
        + id : int <<PK>>
        + entite_id : int <<FK>>
        + region : string
        + ville : string
        + secretariat_telephone : string
        + directeur_agent_id : int <<FK, nullable>>
        + secretaire_agent_id : int <<FK, nullable>>
        --
        + entite() : BelongsTo<Entite>
        + directeur() : BelongsTo<Agent>
        + secretaire() : BelongsTo<Agent>
        + caisses() : HasMany<Caisse>
        + agences() : HasMany<Agence>
        + directServices() : HasMany<Service>
        + villes() : HasMany<Ville>
        + agents() : HasMany<Agent>
    }

    class Caisse {
        + id : int <<PK>>
        + delegation_technique_id : int <<FK>>
        + ville_id : int <<FK, nullable>>
        + direction_id : int <<FK, nullable>>
        + nom : string
        + annee_ouverture : int
        + quartier : string
        + secretariat_telephone : string
        + directeur_agent_id : int <<FK, nullable>>
        + secretaire_agent_id : int <<FK, nullable>>
        --
        + delegationTechnique() : BelongsTo<DelegationTechnique>
        + ville() : BelongsTo<Ville>
        + direction() : BelongsTo<Direction>
        + directeur() : BelongsTo<Agent>
        + secretaire() : BelongsTo<Agent>
        + agences() : HasMany<Agence>
        + services() : HasMany<Service>
        + objectifs() : MorphMany<Objectif>
    }

    class Agence {
        + id : int <<PK>>
        + delegation_technique_id : int <<FK>>
        + caisse_id : int <<FK>>
        + nom : string
        + chef_agent_id : int <<FK, nullable>>
        + secretaire_agent_id : int <<FK, nullable>>
        --
        + delegationTechnique() : BelongsTo<DelegationTechnique>
        + caisse() : BelongsTo<Caisse>
        + chef() : BelongsTo<Agent>
        + secretaire() : BelongsTo<Agent>
        + guichets() : HasMany<Guichet>
        + agents() : HasMany<Agent>
    }

    class Guichet {
        + id : int <<PK>>
        + agence_id : int <<FK>>
        + nom : string
        + chef_agent_id : int <<FK, nullable>>
        --
        + agence() : BelongsTo<Agence>
        + chef() : BelongsTo<Agent>
        + agents() : HasMany<Agent>
    }

    class Ville {
        + id : int <<PK>>
        + delegation_technique_id : int <<FK>>
        + nom : string
        --
        + delegationTechnique() : BelongsTo<DelegationTechnique>
    }

    class Agent {
        + id : int <<PK>>
        + entite_id : int <<FK, nullable>>
        + direction_id : int <<FK, nullable>>
        + delegation_technique_id : int <<FK, nullable>>
        + caisse_id : int <<FK, nullable>>
        + agence_id : int <<FK, nullable>>
        + guichet_id : int <<FK, nullable>>
        + service_id : int <<FK, nullable>>
        + nom : string
        + prenom : string
        + sexe : string
        + email : string
        + numero_telephone : string
        + photo_path : string
        + fonction : string
        + date_debut_fonction : date
        --
        + user() : HasOne<User>
        + entite() : BelongsTo<Entite>
        + direction() : BelongsTo<Direction>
        + delegationTechnique() : BelongsTo<DelegationTechnique>
        + caisse() : BelongsTo<Caisse>
        + agence() : BelongsTo<Agence>
        + guichet() : BelongsTo<Guichet>
        + service() : BelongsTo<Service>
        + directedDirection() : HasOne<Direction>
        + directedDelegation() : HasOne<DelegationTechnique>
        + directedCaisse() : HasOne<Caisse>
        + ledAgence() : HasOne<Agence>
        + ledGuichet() : HasOne<Guichet>
        + ledService() : HasOne<Service>
        + objectifs() : MorphMany<Objectif>
        + evaluations() : MorphMany<Evaluation>
    }
}

' ═══════════════════════════════════════════════════════════════════
'  PACKAGE : SERVICES APPLICATIFS
' ═══════════════════════════════════════════════════════════════════
package "Services Applicatifs" #fef3c7 {

    class AgentAccountService {
        - FONCTION_ROLE : array
        --
        + ensureAccount(agent: Agent) : User
        + deactivateAccount(agent: Agent) : void
        + {static} roleForFonction(fonction: string) : string
    }

    class Setting {
        + id : int <<PK>>
        + key : string
        + value : text
        --
        + {static} get(key: string, default: mixed) : mixed
        + {static} set(key: string, value: mixed) : void
    }

    class Formation {
        + id : int <<PK>>
        + agent_id : int <<FK, nullable>>
        + titre : string
        + description : text
        + date_debut : date
        + date_fin : date
        + statut : string
        --
        + agent() : BelongsTo<Agent>
    }
}

AgentAccountService ..> User : "crée / active"
AgentAccountService ..> Agent : "lit"
Formation "0..*" }o--o| "0..1" Agent : "agent_id"

' ═══════════════════════════════════════════════════════════════════
'  PACKAGE : OBJECTIFS
' ═══════════════════════════════════════════════════════════════════
package "Objectifs" #fef9c3 {

    class Annee {
        + id : int <<PK>>
        + annee : int
        --
        + objectifs() : HasMany<Objectif>
        + evaluations() : HasMany<Evaluation>
    }

    class Objectif {
        + id : int <<PK>>
        + assignable_type : string <<morph>>
        + assignable_id : int <<morph>>
        + annee_id : int <<FK>>
        + date : date
        + date_echeance : date
        + commentaire : text
        + avancement_percentage : int
        --
        + assignable() : MorphTo
        + annee() : BelongsTo<Annee>
    }

    class FicheObjectif {
        + id : int <<PK>>
        + assignable_type : string <<morph>>
        + assignable_id : int <<morph>>
        + annee_id : int <<FK>>
        + titre : string
        + date : date
        + date_echeance : date
        + avancement_percentage : int
        + statut : enum[en_attente, acceptee, refusee]
        --
        + assignable() : MorphTo
        + periode() : BelongsTo<Annee>
        + objectifs() : HasMany<LigneFicheObjectif>
    }

    class LigneFicheObjectif {
        + id : int <<PK>>
        + fiche_objectif_id : int <<FK>>
        + description : text
        + note_obtenue : decimal(10,2)
        --
        + ficheObjectif() : BelongsTo<FicheObjectif>
    }
}

' ═══════════════════════════════════════════════════════════════════
'  PACKAGE : ÉVALUATIONS
' ═══════════════════════════════════════════════════════════════════
package "Évaluations" #fce7f3 {

    class Evaluation {
        + id : int <<PK>>
        + evaluable_type : string <<morph>>
        + evaluable_id : int <<morph>>
        + evaluable_role : string
        + annee_id : int <<FK>>
        + evaluateur_id : int <<FK>>
        + date_debut : date
        + date_fin : date
        + moyenne_subjectifs : decimal(5,2)
        + note_criteres_subjectifs : decimal(5,2)
        + moyenne_objectifs : decimal(5,2)
        + note_criteres_objectifs : decimal(5,2)
        + note_objectifs : int
        + note_manuelle : int
        + note_finale : decimal(5,2)
        + commentaire : text
        + points_a_ameliorer : text
        + strategies_amelioration : text
        + commentaires_evalue : text
        + signature_evalue_nom : string
        + signature_directeur_nom : string
        + signature_evaluateur_nom : string
        + date_signature_evalue : date
        + date_signature_directeur : date
        + date_signature_evaluateur : date
        + statut : enum[brouillon, soumis, valide, refuse]
        --
        + evaluable() : MorphTo
        + evaluateur() : BelongsTo<User>
        + annee() : BelongsTo<Annee>
        + identification() : HasOne<EvaluationIdentification>
        + criteres() : HasMany<EvaluationCritere>
    }

    class EvaluationIdentification {
        + id : int <<PK>>
        + evaluation_id : int <<FK>>
        + nom_prenom : string
        + semestre : string
        + matricule : string
        + poste : string
        + emploi : string
        + niveau : string
        + categorie : string
        + anciennete : string
        + sexe : string
        + direction : string
        + direction_service : string
        + date_recrutement : date
        + date_evaluation : date
        + date_titularisation : date
        + date_naissance : date
        + date_confirmation : date
        + date_affectation : date
        + formations : array
        + experiences : array
        --
        + evaluation() : BelongsTo<Evaluation>
    }

    class EvaluationCritere {
        + id : int <<PK>>
        + evaluation_id : int <<FK>>
        + type : enum[subjectif, objectif]
        + ordre : int
        + titre : string
        + description : text
        + note_globale : decimal(5,2)
        + observation : text
        + source_template_id : int <<FK, nullable>>
        + source_fiche_objectif_id : int <<FK, nullable>>
        + source_fiche_objectif_objectif_id : int <<FK, nullable>>
        --
        + evaluation() : BelongsTo<Evaluation>
        + sousCriteres() : HasMany<EvaluationSousCritere>
        + ficheObjectif() : BelongsTo<FicheObjectif>
        + ligneFicheObjectif() : BelongsTo<LigneFicheObjectif>
    }

    class EvaluationSousCritere {
        + id : int <<PK>>
        + evaluation_critere_id : int <<FK>>
        + ordre : int
        + libelle : string
        + note : decimal(5,2)
        + observation : text
        --
        + critere() : BelongsTo<EvaluationCritere>
    }
}

' ═══════════════════════════════════════════════════════════════════
'  PACKAGE : TEMPLATES CRITÈRES
' ═══════════════════════════════════════════════════════════════════
package "Templates Critères Subjectifs" #ede9fe {

    class SubjectiveCriteriaTemplate {
        + id : int <<PK>>
        + ordre : int
        + titre : string
        + description : text
        + is_active : bool
        --
        + subcriteria() : HasMany<SubjectiveSubcriteriaTemplate>
    }

    class SubjectiveSubcriteriaTemplate {
        + id : int <<PK>>
        + subjective_criteria_template_id : int <<FK>>
        + ordre : int
        + libelle : string
        --
        + template() : BelongsTo<SubjectiveCriteriaTemplate>
    }
}

' ═══════════════════════════════════════════════════════════════════
'  RELATIONS — Authentification
' ═══════════════════════════════════════════════════════════════════
User "1" --o{ "0..*" User : "subordonnes directs\n(manager_id)"
User "1" --> "0..1" Agent : "agent_id"
User "0..*" }o--o{ "0..*" Alerte : "alerte_user\n(pivot)"
User "1" --o{ "0..*" Activite : "user_id"
User "1" --> "0..*" Alerte : "createur\n(created_by)"

' ═══════════════════════════════════════════════════════════════════
'  RELATIONS — Structure organisationnelle
' ═══════════════════════════════════════════════════════════════════
Entite "1" --o{ "0..*" Direction : "entite_id"
Entite "1" --o{ "0..*" DelegationTechnique : "entite_id"

Direction "1" --o{ "0..*" Service : "direction_id"
Direction "1" --o{ "0..*" Agent : "direction_id"
Direction "1" --o{ "0..*" Caisse : "superviseur_direction_id"

DelegationTechnique "1" --o{ "0..*" Caisse : "delegation_technique_id"
DelegationTechnique "1" --o{ "0..*" Agence : "delegation_technique_id"
DelegationTechnique "1" --o{ "0..*" Service : "delegation_technique_id"
DelegationTechnique "1" --o{ "0..*" Ville : "delegation_technique_id"
DelegationTechnique "1" --o{ "0..*" Agent : "delegation_technique_id"

Caisse "1" --o{ "0..*" Agence : "caisse_id"
Caisse "1" --o{ "0..*" Service : "caisse_id"
Caisse "1" --o{ "0..*" Agent : "caisse_id"

Agence "1" --o{ "0..*" Guichet : "agence_id"
Agence "1" --o{ "0..*" Agent : "agence_id"

Guichet "1" --o{ "0..*" Agent : "guichet_id"

Agent "1" --o{ "0..*" User : "agent_id"

' Postes de direction (agents nommés à la tête d'une entité)
Agent "0..1" ..> "0..1" Direction : "directeur"
Agent "0..1" ..> "0..1" DelegationTechnique : "directeur"
Agent "0..1" ..> "0..1" Caisse : "directeur"
Agent "0..1" ..> "0..1" Agence : "chef"
Agent "0..1" ..> "0..1" Guichet : "chef"
Agent "0..1" ..> "0..1" Service : "chef"

' ═══════════════════════════════════════════════════════════════════
'  RELATIONS — Objectifs (polymorphiques)
' ═══════════════════════════════════════════════════════════════════
Annee "1" --o{ "0..*" Objectif : "annee_id"
Annee "1" --o{ "0..*" FicheObjectif : "annee_id"
Annee "1" --o{ "0..*" Evaluation : "annee_id"

FicheObjectif "1" --o{ "0..*" LigneFicheObjectif : "fiche_objectif_id"

' Polymorphisme assignable (Objectif et FicheObjectif)
Entite "1" ..o{ "0..*" Objectif : "assignable\n(morph)"
Direction "1" ..o{ "0..*" Objectif : "assignable\n(morph)"
Service "1" ..o{ "0..*" Objectif : "assignable\n(morph)"
Caisse "1" ..o{ "0..*" Objectif : "assignable\n(morph)"
Agent "1" ..o{ "0..*" Objectif : "assignable\n(morph)"

User "1" ..o{ "0..*" FicheObjectif : "assignable\n(morph)"
Direction "1" ..o{ "0..*" FicheObjectif : "assignable\n(morph)"
Caisse "1" ..o{ "0..*" FicheObjectif : "assignable\n(morph)"
DelegationTechnique "1" ..o{ "0..*" FicheObjectif : "assignable\n(morph)"

' ═══════════════════════════════════════════════════════════════════
'  RELATIONS — Évaluations (polymorphiques)
' ═══════════════════════════════════════════════════════════════════
User "1" --o{ "0..*" Evaluation : "evaluateur\n(evaluateur_id)"

Evaluation "1" --o| "0..1" EvaluationIdentification : "evaluation_id"
Evaluation "1" --o{ "0..*" EvaluationCritere : "evaluation_id"
EvaluationCritere "1" --o{ "0..*" EvaluationSousCritere : "evaluation_critere_id"

' Polymorphisme évaluable
User "1" ..o{ "0..*" Evaluation : "evaluable\n(morph)"
Agent "1" ..o{ "0..*" Evaluation : "evaluable\n(morph)"
Direction "1" ..o{ "0..*" Evaluation : "evaluable\n(morph)"
Caisse "1" ..o{ "0..*" Evaluation : "evaluable\n(morph)"

' Lien critères objectifs → source fiche
EvaluationCritere "0..*" ..> "0..1" FicheObjectif : "source_fiche_objectif_id"
EvaluationCritere "0..*" ..> "0..1" LigneFicheObjectif : "source_ligne_id"

' ═══════════════════════════════════════════════════════════════════
'  RELATIONS — Templates
' ═══════════════════════════════════════════════════════════════════
SubjectiveCriteriaTemplate "1" --o{ "0..*" SubjectiveSubcriteriaTemplate : "subjective_criteria_template_id"
EvaluationCritere "0..*" ..> "0..1" SubjectiveCriteriaTemplate : "source_template_id"

@enduml
